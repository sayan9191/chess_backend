# ── Recommended for Vercel (password can contain @ # without encoding) ──
DB_HOST=db.xxxx.supabase.co
DB_USER=postgres
DB_PASSWORD=your-raw-supabase-password
DB_NAME=postgres
DB_PORT=5432

# ── OR single URL (password MUST be URL-encoded: @ → %40, # → %23) ──
# DATABASE_URL=postgresql+asyncpg://postgres:ENCODED_PASSWORD@db.xxxx.supabase.co:5432/postgres

JWT_SECRET_KEY=replace-with-a-long-random-string-at-least-32-chars
CORS_ORIGINS=https://your-app.vercel.app,http://localhost:3000
ENVIRONMENT=production
LOG_FORMAT=json
LOG_LEVEL=INFO

# Optional — Stockfish is not available on Vercel; engine falls back to random legal moves
# STOCKFISH_PATH=stockfish
