# Copy into Vercel → Project → Settings → Environment Variables
#
# ⚠️  PASSWORD URL-ENCODING (required if password has @ # / : etc.)
#     @  →  %40     #  →  %23     /  →  %2F
#     Example: Bokachoda@#2001  →  Bokachoda%40%232001
#
# Best: Supabase Dashboard → Database → Connection string → URI (pre-encoded)

DATABASE_URL=postgresql+asyncpg://postgres:YOUR_URL_ENCODED_PASSWORD@db.xxxx.supabase.co:5432/postgres

JWT_SECRET_KEY=replace-with-a-long-random-string-at-least-32-chars
CORS_ORIGINS=https://your-app.vercel.app,http://localhost:3000
ENVIRONMENT=production
LOG_FORMAT=json
LOG_LEVEL=INFO

# Optional — Stockfish is not available on Vercel; engine falls back to random legal moves
# STOCKFISH_PATH=stockfish
